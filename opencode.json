{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "edgartools": {
      "type": "local",
      "command": ["python", "-m", "edgar.ai"],
      "environment": {
        "EDGAR_IDENTITY": "John Ruckfelar john.r97@gmail.com"
      },
      "enabled": true
    },
    "yahoo-finance": {
      "type": "local",
      "command": ["uvx", "yfmcp@latest"],
      "enabled": true
    }
  },
  "permission": {
    "bash": {
      "*": "allow",
      "websearch": "allow",
      "codesearch": "allow",
      "question": "allow",
      "Stop-Process*": "ask",
      "Kill-Process*": "ask",
      "taskkill*": "ask",
      "rm*": "ask"
    }
  },
  "plugin": ["opencode-skill-creator"]
}
