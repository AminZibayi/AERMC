{
  "skill_name": "sec-risk-research",
  "evals": [
    {
      "id": 1,
      "name": "jpm-full-report",
      "prompt": "Do a full ERM risk analysis on JPM",
      "expected_output": "Full 13-phase ERM report for JPM saved to ./dist/JPM/ERM_Report.md",
      "assertions": [
        {"type": "file_exists", "path": "./dist/JPM/ERM_Report.md"},
        {"type": "contains_section", "path": "./dist/JPM/ERM_Report.md", "text": "# Enterprise Risk Management Report"},
        {"type": "contains_table", "path": "./dist/JPM/ERM_Report.md", "headers": ["Field", "Value", "Source"]},
        {"type": "contains_mermaid", "path": "./dist/JPM/ERM_Report.md"},
        {"type": "contains_csv", "path": "./dist/JPM/ERM_Report.md", "columns": ["Metric", "FY2023", "FY2024", "FY2025"]}
      ]
    },
    {
      "id": 2,
      "name": "apple-risk-factors",
      "prompt": "What are the material risk factors for Apple? Do a SEC filing analysis",
      "expected_output": "Risk factor register extracted in report",
      "assertions": [
        {"type": "file_exists", "path": "./dist/AAPL/ERM_Report.md"},
        {"type": "contains_section", "path": "./dist/AAPL/ERM_Report.md", "text": "Risk Factor Register"},
        {"type": "contains_phrase", "path": "./dist/AAPL/ERM_Report.md", "text": "cyber attack"},
        {"type": "contains_csv", "path": "./dist/AAPL/ERM_Report.md", "columns": ["Risk_Factor_Title", "Verbatim_Excerpt", "Filing_Source"]}
      ]
    },
    {
      "id": 3,
      "name": "msft-credit-risk",
      "prompt": "credit risk assessment for Microsoft based on SEC filings",
      "expected_output": "Report with credit risk section",
      "assertions": [
        {"type": "file_exists", "path": "./dist/MSFT/ERM_Report.md"},
        {"type": "contains_section", "path": "./dist/MSFT/ERM_Report.md", "text": "Credit Risk Profile"},
        {"type": "contains_phrase", "path": "./dist/MSFT/ERM_Report.md", "text": "concentration"}
      ]
    },
    {
      "id": 4,
      "name": "generic-trigger-test",
      "prompt": "I need to understand the enterprise risks facing Tesla",
      "expected_output": "Skill triggers and produces report",
      "assertions": [
        {"type": "file_exists", "path": "./dist/TSLA/ERM_Report.md"},
        {"type": "contains_section", "path": "./dist/TSLA/ERM_Report.md", "text": "Company Context Brief"}
      ]
    },
    {
      "id": 5,
      "name": "no-trigger-should-not-fire",
      "prompt": "read the file AGENTS.md and summarize it",
      "expected_output": "Skill should NOT trigger for this",
      "assertions": []
    },
    {
      "id": 6,
      "name": "jpm-tesla-risk-analysis",
      "prompt": "risk analysis on TSLA — I want to know their top SEC filing risks",
      "expected_output": "Report with Tesla risk analysis",
      "assertions": [
        {"type": "file_exists", "path": "./dist/TSLA/ERM_Report.md"},
        {"type": "contains_section", "path": "./dist/TSLA/ERM_Report.md", "text": "Risk Factor Register"},
        {"type": "contains_phrase", "path": "./dist/TSLA/ERM_Report.md", "text": "operational"}
      ]
    }
  ]
}
